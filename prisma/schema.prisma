generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String                   @id @default(cuid())
  name                    String
  email                   String                   @unique
  emailVerified           Boolean                  @default(false)
  image                   String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  resetPasswordToken      String?
  resetPasswordExpires    DateTime?
  accounts                Account[]
  aiCache                 AiCache?
  feedbacks               Feedback[]
  notifications           Notification[]
  opportunityApplications OpportunityApplication[]
  opportunityBookmarks    OpportunityBookmark[]
  resumeAnalysis          ResumeAnalysis?
  roadmapProgress         RoadmapProgress[]
  sessions                Session[]
  profile                 StudentProfile?
  studyPlans              StudyPlan[]
  studyPreference         StudyPreference?
  studyTasks              StudyTask[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verifications")
}

model StudentProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  branch            String?
  year              Int?
  cgpa              Float?
  skills            String[]
  interests         String[]
  careerGoal        String?
  selectedCareer    String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  bio               String?
  github            String?
  linkedin          String?
  phone             String?
  academicProjects  Json?
  certifications    Json?
  companyName       String?
  currentJobTitle   String?
  currentSalary     String?
  desiredRole       String?
  expectedSalary    String?
  experienceLevel   String?
  industry          String?
  preferredDomains  String[]
  projects          Json?
  userType          String   @default("Student")
  yearsOfExperience Float?
  leetCode          String?
  degree            String?
  semester          String?
  university        String?
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("student_profiles")
}

model Career {
  id          String        @id @default(cuid())
  name        String        @unique
  description String?
  createdAt   DateTime      @default(now())
  projects    Json?
  resources   Json?
  roadmap     Json?
  salaryRange String?
  skills      CareerSkill[]

  @@map("careers")
}

model Skill {
  id        String        @id @default(cuid())
  name      String        @unique
  createdAt DateTime      @default(now())
  careers   CareerSkill[]

  @@map("skills")
}

model CareerSkill {
  id       String @id @default(cuid())
  careerId String
  skillId  String
  career   Career @relation(fields: [careerId], references: [id], onDelete: Cascade)
  skill    Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([careerId, skillId])
  @@map("career_skills")
}

model AiCache {
  id              String   @id @default(cuid())
  userId          String   @unique
  recommendation  Json?
  opportunities   Json?
  skillGap        Json?
  roadmap         Json?
  roadmapAnalysis Json?
  resumeMatch     Json?
  placement       Json?
  progress        Json?
  profileHash     String
  source          String   @default("gemini")
  generatedAt     DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ai_caches")
}

model RoadmapProgress {
  id          String    @id @default(cuid())
  userId      String
  career      String
  phaseId     Int
  status      String    @default("NOT_STARTED")
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, career, phaseId])
  @@map("roadmap_progress")
}

model Opportunity {
  id             String                   @id @default(cuid())
  title          String
  company        String
  companyLogo    String?
  location       String
  workMode       String
  type           String
  duration       String?
  stipend        String?
  deadline       DateTime?
  applyUrl       String?
  requiredSkills String[]
  description    String?
  eligibility    String?
  source         String                   @default("system")
  postedDate     DateTime                 @default(now())
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  applications   OpportunityApplication[]
  bookmarks      OpportunityBookmark[]

  @@map("opportunities")
}

model OpportunityBookmark {
  id            String      @id @default(cuid())
  userId        String
  opportunityId String
  createdAt     DateTime    @default(now())
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, opportunityId])
  @@map("opportunity_bookmarks")
}

model OpportunityApplication {
  id            String      @id @default(cuid())
  userId        String
  opportunityId String
  status        String      @default("APPLIED")
  appliedAt     DateTime    @default(now())
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, opportunityId])
  @@map("opportunity_applications")
}

model ResumeAnalysis {
  id                        String   @id @default(cuid())
  userId                    String   @unique
  fileUrl                   String?
  fileName                  String
  fileSize                  String
  resumeText                String?
  parsedData                Json?
  atsScore                  Int
  overallScore              Int
  careerFit                 String?
  strengths                 Json
  weaknesses                Json
  matchedSkills             Json
  missingSkills             Json
  missingSections           Json
  improvements              Json
  suggestedProjects         Json
  recommendedCertifications Json
  summary                   String
  executiveSummary          String?
  keywordSuggestions        Json?
  finalVerdict              String?
  structure                 String?
  writingQuality            String?
  formatting                String?
  recruiterImpression       String?
  analyzedAt                DateTime @default(now())
  user                      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("resume_analysis")
}

model StudyPlan {
  id        String      @id @default(cuid())
  userId    String
  title     String
  type      String
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks     StudyTask[]

  @@map("study_plans")
}

model StudyTask {
  id               String          @id @default(cuid())
  planId           String?
  userId           String
  title            String
  description      String
  skill            String
  scheduledAt      DateTime
  estimatedMinutes Int
  priority         StudyPriority
  status           StudyTaskStatus @default(PENDING)
  reminderSent     Boolean         @default(false)
  isArchived       Boolean         @default(false)
  completedAt      DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  plan             StudyPlan?      @relation(fields: [planId], references: [id], onDelete: Cascade)
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("study_tasks")
}

model Notification {
  id           String    @id @default(cuid())
  userId       String
  type         String
  title        String
  message      String
  taskId       String?
  actionUrl    String?
  module       String    @default("SYSTEM")
  priority     String    @default("INFO")
  actionType   String?
  icon         String?
  metadata     Json?
  isRead       Boolean   @default(false)
  scheduledFor DateTime?
  expiresAt    DateTime?
  sent         Boolean   @default(false)
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model StudyPreference {
  id                 String   @id @default(cuid())
  userId             String   @unique
  hoursPerDay        Float
  preferredStartTime String
  studyDays          String[]
  difficulty         String
  focusArea          String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("study_preferences")
}

model Feedback {
  id            String         @id @default(cuid())
  userId        String
  category      String
  module        String
  subject       String
  description   String
  priority      String
  attachmentUrl String?
  status        FeedbackStatus @default(OPEN)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("feedbacks")
}

enum StudyPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum StudyTaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  MISSED
  SKIPPED
}

enum FeedbackStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}
